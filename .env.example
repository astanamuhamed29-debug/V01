# ── SELF-OS environment variables ────────────────────────────────
# Copy this file to .env and fill in real values before running.

# ── LLM ─────────────────────────────────────────────────────────
# API key for OpenRouter (required when SELFOS_USE_LLM=1)
OPENROUTER_API_KEY=your_openrouter_api_key
# Model to use (OPENROUTER_MODEL_ID is an accepted alias for OPENROUTER_MODEL)
OPENROUTER_MODEL_ID=deepseek/deepseek-v3-2
# Set to 0 to run without an LLM (useful for tests / local dev)
SELFOS_USE_LLM=1
# Set to false to skip live LLM reply generation
LIVE_REPLY_ENABLED=true

# ── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_token_here

# ── Storage ──────────────────────────────────────────────────────
DB_PATH=data/self_os.db

# ── Qdrant (vector search) ───────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=self_os_nodes

# ── Neo4j (semantic memory, optional) ───────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# ── Observability ────────────────────────────────────────────────
# LOG_LEVEL accepts DEBUG | INFO | WARNING | ERROR (SELFOS_LOG_LEVEL is an alias)
LOG_LEVEL=INFO
MAX_TEXT_LENGTH=10000
