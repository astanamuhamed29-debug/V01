# ── LLM / OpenRouter ──────────────────────────────────────────────────────────
# API key for OpenRouter (https://openrouter.ai). Required for all LLM features.
OPENROUTER_API_KEY=your_openrouter_api_key

# Model to use via OpenRouter. OPENROUTER_MODEL takes precedence over
# OPENROUTER_MODEL_ID when both are set. Check openrouter.ai for available IDs.
OPENROUTER_MODEL_ID=deepseek/deepseek-v3-2
# OPENROUTER_MODEL=deepseek/deepseek-v3-2   # alternative / override

# Set to 0 to disable all LLM calls (useful for offline testing).
SELFOS_USE_LLM=1

# ── Interface ─────────────────────────────────────────────────────────────────
# Telegram Bot API token. Required when running the Telegram interface.
TELEGRAM_BOT_TOKEN=your_token_here

# When true the bot sends live LLM-generated replies to users.
# Set to false for dry-run / test mode.
LIVE_REPLY_ENABLED=true

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the SQLite database file (default: data/self_os.db).
# DB_PATH=data/self_os.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level for the application. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# SELFOS_LOG_LEVEL=INFO

# Maximum number of characters accepted per incoming message.
# MAX_TEXT_LENGTH=10000

# ── Neo4j (optional — Stage 2 semantic memory layer) ──────────────────────────
# Leave unset to keep Neo4j disabled; SELF-OS will use SQLite only.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
# NEO4J_DATABASE=neo4j

# ── Qdrant (optional — vector embeddings storage) ────────────────────────────
# Leave unset to keep Qdrant disabled; vector search features will be unavailable.
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=self_os_nodes
